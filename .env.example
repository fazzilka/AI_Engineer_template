# Application
APP__NAME="AI Engineer Template"
APP__ENVIRONMENT=local
APP__ALLOW_FAKE_BACKENDS=false
API__PREFIX=/api/v1
API__DOCS_ENABLED=true
API__MAX_REQUEST_BODY_BYTES=22020096
OBSERVABILITY__LOG_LEVEL=INFO

# Offline mode forces local model files and disables URL ingestion.
OFFLINE_MODE=false
HF_HUB_OFFLINE=0

# Generator: fake is the zero-download default.
MODEL__BACKEND=fake
MODEL__SOURCE=filesystem
MODEL__ID=
MODEL__PATH=./models/generator
MODEL__REVISION=
MODEL__LOCAL_FILES_ONLY=true
MODEL__TRUST_REMOTE_CODE=false
MODEL__DEVICE=auto
MODEL__DTYPE=auto
MODEL__TASK=text-generation
MODEL__LOAD_ON_STARTUP=false
MODEL__MAX_INPUT_TOKENS=4096
MODEL__MAX_NEW_TOKENS=512
MODEL__TEMPERATURE=0.2
MODEL__TOP_P=0.9
MODEL__DO_SAMPLE=false
MODEL__REPETITION_PENALTY=1.05
MODEL__CONCURRENCY=1
MODEL__TIMEOUT_SECONDS=120
MODEL__ALIAS=fake-model

# Embeddings: deterministic fake embeddings keep tests and first run offline.
EMBEDDINGS__BACKEND=fake
EMBEDDINGS__SOURCE=filesystem
EMBEDDINGS__ID=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDINGS__PATH=./models/embeddings
EMBEDDINGS__REVISION=
EMBEDDINGS__LOCAL_FILES_ONLY=true
EMBEDDINGS__DEVICE=auto
EMBEDDINGS__NORMALIZE=true
EMBEDDINGS__BATCH_SIZE=32
EMBEDDINGS__QUERY_PREFIX=
EMBEDDINGS__DOCUMENT_PREFIX=
EMBEDDINGS__FAKE_DIMENSION=64
EMBEDDINGS__ALIAS=local-embeddings

# Qdrant: local mode persists under ./data; memory is intended for tests/evals.
QDRANT__MODE=local
QDRANT__PATH=./data/qdrant
QDRANT__URL=http://localhost:6333
QDRANT__COLLECTION=documents
QDRANT__DISTANCE=cosine
QDRANT__RETRIEVAL_MODE=dense
QDRANT__TOP_K=5
QDRANT__SCORE_THRESHOLD=
QDRANT__PREFER_GRPC=false
QDRANT__REQUEST_TIMEOUT_SECONDS=10
QDRANT__SPARSE_MODEL_ID=Qdrant/bm25
QDRANT__SPARSE_CACHE_DIR=./models/fastembed

# Chunking and ingestion limits
CHUNKING__CHUNK_SIZE=1000
CHUNKING__CHUNK_OVERLAP=150
CHUNKING__SEPARATORS=
CHUNKING__LENGTH_FUNCTION=characters
INGESTION__MAX_FILE_BYTES=20971520
INGESTION__MAX_PDF_PAGES=500
INGESTION__MAX_EXTRACTED_CHARACTERS=5000000
INGESTION__MAX_FILES_PER_REQUEST=1

# Safe URL ingestion
WEB__ENABLED=true
WEB__MAX_REDIRECTS=3
WEB__CONNECT_TIMEOUT_SECONDS=5
WEB__READ_TIMEOUT_SECONDS=15
WEB__MAX_RESPONSE_BYTES=5242880
WEB__ALLOW_PRIVATE_HOSTS=false
WEB__USER_AGENT=AI-Engineer-Template/1.0
WEB__MAX_RETRIES=2

# RAG context budget
RAG__TOP_K=5
RAG__MAX_CONTEXT_CHUNKS=8
RAG__MAX_CONTEXT_CHARACTERS=16000
RAG__MAX_CONTEXT_TOKENS=3000
RAG__RETURN_SOURCES=true
RAG__MIN_RELEVANT_CHUNKS=1
RAG__CITATION_SNIPPET_CHARACTERS=300
