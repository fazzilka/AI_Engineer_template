# Application
APP_NAME="AI Engineer Template"
APP_ENV=local
LOG_LEVEL=INFO
API_PREFIX=/api/v1
DOCS_ENABLED=true

# The fake provider keeps the first run offline and deterministic.
LLM__PROVIDER=fake
LLM__MODEL=fake-model
LLM__API_KEY=
LLM__BASE_URL=
LLM__TEMPERATURE=0.2
LLM__MAX_TOKENS=1024
LLM__TIMEOUT_SECONDS=30
LLM__MAX_RETRIES=2

# OpenAI example:
# LLM__PROVIDER=openai_compatible
# LLM__MODEL=your-model-name
# LLM__API_KEY=your-api-key

# Local OpenAI-compatible server example:
# LLM__PROVIDER=openai_compatible
# LLM__MODEL=your-local-model
# LLM__API_KEY=local
# LLM__BASE_URL=http://host.docker.internal:11434/v1
